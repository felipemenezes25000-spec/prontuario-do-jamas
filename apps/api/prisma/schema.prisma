// ============================================================================
// DIGITAL SIGNATURE — ICP-Brasil (CFM Resolution 2.299/2021)
// ============================================================================

enum SignatureType {
  CLINICAL_NOTE
  PRESCRIPTION
  DISCHARGE_SUMMARY
  LAB_RESULT
  SURGICAL_REPORT
  MEDICAL_CERTIFICATE
}

enum CertificateType {
  ICP_BRASIL_A1       // Software certificate (PFX/P12)
  ICP_BRASIL_A3       // Hardware token/smart card
  CLOUD_CERTIFICATE   // Cloud-based (e.g., BirdID, VIDaaS)
}

enum SignatureStandard {
  CADES_BES   // Basic Electronic Signature
  CADES_T     // With timestamp
  PADES_B     // PDF basic
  XADES_BES   // XML basic
}

model DigitalSignature {
  id                  String            @id @default(uuid()) @map("id")
  tenantId            String            @map("tenant_id")
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  documentId          String?           @map("document_id")
  document            ClinicalDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  clinicalNoteId      String?           @map("clinical_note_id")
  clinicalNote        ClinicalNote?     @relation(fields: [clinicalNoteId], references: [id], onDelete: SetNull)
  prescriptionId      String?           @map("prescription_id")
  prescription        Prescription?     @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)

  signerId            String            @map("signer_id")
  signer              User              @relation("DigitalSignatureSigner", fields: [signerId], references: [id], onDelete: Restrict)

  signatureType       SignatureType     @map("signature_type")
  certificateType     CertificateType   @map("certificate_type")

  // Certificate info extracted from ICP-Brasil certificate
  certificateSubject  String            @map("certificate_subject")
  certificateIssuer   String            @map("certificate_issuer")
  certificateSerial   String            @map("certificate_serial")
  certificateNotBefore DateTime         @map("certificate_not_before")
  certificateNotAfter  DateTime         @map("certificate_not_after")

  // Signature data
  signatureHash       String            @map("signature_hash")
  signatureValue      String            @db.Text @map("signature_value")
  signedAt            DateTime          @default(now()) @map("signed_at")

  // Verification
  verified            Boolean           @default(false) @map("verified")
  verifiedAt          DateTime?         @map("verified_at")
  verificationChain   String?           @db.Text @map("verification_chain")

  // CAdES/PAdES metadata (CFM Resolution 2.299/2021)
  signatureStandard   SignatureStandard @map("signature_standard")
  timestampToken      String?           @db.Text @map("timestamp_token")

  createdAt           DateTime          @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([documentId])
  @@index([clinicalNoteId])
  @@index([prescriptionId])
  @@index([signerId])
  @@map("digital_signatures")
}

