// ============================================================================
// MODELS
// ============================================================================

model Tenant {
  id                    String    @id @default(uuid()) @map("id")
  name                  String    @map("name")
  slug                  String    @unique @map("slug")
  cnpj                  String    @unique @map("cnpj")
  type                  TenantType @map("type")
  address               String?   @map("address")
  city                  String?   @map("city")
  state                 String?   @map("state")
  cep                   String?   @map("cep")
  phone                 String?   @map("phone")
  email                 String?   @map("email")
  website               String?   @map("website")
  logo                  String?   @map("logo")
  primaryColor          String?   @map("primary_color")
  secondaryColor        String?   @map("secondary_color")
  cnesCode              String?   @map("cnes_code")
  sbisLevel             SbisLevel @default(NONE) @map("sbis_level")
  maxBeds               Int       @default(0) @map("max_beds")
  maxUsers              Int       @default(0) @map("max_users")
  plan                  TenantPlan @default(FREE) @map("plan")
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")
  isActive              Boolean   @default(true) @map("is_active")
  settings              Json?     @map("settings")
  ssoEnabled            Boolean   @default(false) @map("sso_enabled")
  ssoProvider           String?   @map("sso_provider")
  ssoConfig             Json?     @map("sso_config")
  ssoDomain             String?   @map("sso_domain")
  ssoAutoProvision      Boolean   @default(false) @map("sso_auto_provision")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  users               User[]
  patients            Patient[]
  encounters          Encounter[]
  beds                Bed[]
  appointments        Appointment[]
  billingEntries      BillingEntry[]
  auditLogs           AuditLog[]
  alerts              ClinicalAlert[]
  notifications       Notification[]
  documents           ClinicalDocument[]
  documentTemplates   DocumentTemplate[]
  admissions          Admission[]
  prescriptions       Prescription[]
  surgicalProcedures    SurgicalProcedure[]
  consentRecords        ConsentRecord[]
  dataRetentionPolicies DataRetentionPolicy[]
  digitalSignatures       DigitalSignature[]
  chemotherapyProtocols   ChemotherapyProtocol[]
  chemotherapyCycles      ChemotherapyCycle[]
  billingAppeals          BillingAppeal[]
  clinicalProtocols       ClinicalProtocol[]
  drugs                   Drug[]
  manchesterFlowcharts    ManchesterFlowchart[]
  examCatalogs            ExamCatalog[]
  dispensations           Dispensation[]
  drugInventory           DrugInventory[]
  clinicalAlertRules      ClinicalAlertRule[]
  nursingHandoffs         NursingHandoff[]

  @@index([slug])
  @@index([cnpj])
  @@index([isActive])
  @@index([ssoDomain])
  @@map("tenants")
}

model User {
  id              String    @id @default(uuid()) @map("id")
  tenantId        String    @map("tenant_id")
  email           String    @unique @map("email")
  passwordHash    String    @map("password_hash")
  name            String    @map("name")
  cpf             String    @unique @map("cpf")
  phone           String?   @map("phone")
  role            UserRole  @map("role")
  avatar          String?   @map("avatar")
  isActive        Boolean   @default(true) @map("is_active")
  mfaEnabled      Boolean   @default(false) @map("mfa_enabled")
  mfaSecret       String?   @map("mfa_secret")
  mfaBackupCodes  String[]  @map("mfa_backup_codes")
  lastLoginAt     DateTime? @map("last_login_at")
  loginCount      Int       @default(0) @map("login_count")
  preferredDevice String?   @map("preferred_device")
  voiceProfileId  String?   @map("voice_profile_id")
  settings          Json?     @map("settings")
  oauthProvider     String?   @map("oauth_provider")
  oauthProviderId   String?   @map("oauth_provider_id")
  oauthProfileData  Json?     @map("oauth_profile_data")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  tenant                    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  doctorProfile             DoctorProfile?
  nurseProfile              NurseProfile?
  schedules                 ProfessionalSchedule[]
  encountersAsDoctor        Encounter[]         @relation("EncounterDoctor")
  encountersAsNurse         Encounter[]         @relation("EncounterNurse")
  encountersAsTriageNurse   Encounter[]         @relation("EncounterTriageNurse")
  clinicalNotes             ClinicalNote[]      @relation("NoteAuthor")
  signedNotes               ClinicalNote[]      @relation("NoteSigner")
  cosignedNotes             ClinicalNote[]      @relation("NoteCosigner")
  prescriptions             Prescription[]      @relation("PrescriptionDoctor")
  doubleCheckedPrescriptions Prescription[]     @relation("PrescriptionDoubleChecker")
  dispensedPrescriptions    Prescription[]      @relation("PrescriptionDispenser")
  vitalSigns                VitalSigns[]
  voiceTranscriptions       VoiceTranscription[] @relation("TranscriptionUser")
  editedTranscriptions      VoiceTranscription[] @relation("TranscriptionEditor")
  triageAssessments         TriageAssessment[]
  nursingNotes              NursingNote[]
  nursingProcesses          NursingProcess[]
  auditLogs                 AuditLog[]
  notifications             Notification[]
  allergiesConfirmed        Allergy[]           @relation("AllergyConfirmer")
  conditionsDiagnosed       ChronicCondition[]  @relation("ConditionDiagnoser")
  vaccinationsApplied       Vaccination[]
  admissionsAdmitting       Admission[]         @relation("AdmittingDoctor")
  admissionsAttending       Admission[]         @relation("AttendingDoctor")
  bedTransfersRequested     BedTransfer[]       @relation("TransferRequester")
  bedTransfersApproved      BedTransfer[]       @relation("TransferApprover")
  bedTransfersExecuted      BedTransfer[]       @relation("TransferExecutor")
  medicationChecks          MedicationCheck[]
  surgeonProcedures         SurgicalProcedure[] @relation("Surgeon")
  firstAssistantProcedures  SurgicalProcedure[] @relation("FirstAssistant")
  anesthesiologistProcedures SurgicalProcedure[] @relation("Anesthesiologist")
  scrubNurseProcedures      SurgicalProcedure[] @relation("ScrubNurse")
  circulatingNurseProcedures SurgicalProcedure[] @relation("CirculatingNurse")
  examsRequested            ExamResult[]        @relation("ExamRequester")
  examsReviewed             ExamResult[]        @relation("ExamReviewer")
  documentsAuthored         ClinicalDocument[]  @relation("DocumentAuthor")
  documentsSigned           ClinicalDocument[]  @relation("DocumentSigner")
  templatesCreated          DocumentTemplate[]
  alertsAcknowledged        ClinicalAlert[]     @relation("AlertAcknowledger")
  alertsResolved            ClinicalAlert[]     @relation("AlertResolver")
  dataRequestsProcessed     DataAccessRequest[]
  appointments              Appointment[]
  fluidBalances             FluidBalance[]
  digitalSignatures         DigitalSignature[]  @relation("DigitalSignatureSigner")
  billingAppeals            BillingAppeal[]     @relation("AppealCreator")
  pharmacistDispensations   Dispensation[]      @relation("PharmacistDispensations")
  handoffsFrom              NursingHandoff[]    @relation("HandoffFrom")
  handoffsTo                NursingHandoff[]    @relation("HandoffTo")

  @@unique([oauthProvider, oauthProviderId])
  @@index([tenantId, email])
  @@index([tenantId, cpf])
  @@index([tenantId, role])
  @@map("users")
}

model DoctorProfile {
  id                        String    @id @default(uuid()) @map("id")
  userId                    String    @unique @map("user_id")
  crm                       String    @map("crm")
  crmState                  String    @map("crm_state")
  specialty                 Specialty @map("specialty")
  subSpecialties            String[]  @map("sub_specialties")
  medicalSchool             String?   @map("medical_school")
  graduationYear            Int?      @map("graduation_year")
  titlePrefix               String    @default("Dr.") @map("title_prefix")
  digitalCertificateSerial  String?   @map("digital_certificate_serial")
  digitalCertificateExpiry  DateTime? @map("digital_certificate_expiry")
  signatureImage            String?   @map("signature_image")
  stampImage                String?   @map("stamp_image")
  consultationDuration      Int       @default(30) @map("consultation_duration")
  maxDailyPatients          Int       @default(20) @map("max_daily_patients")
  teleconsultationEnabled   Boolean   @default(false) @map("teleconsultation_enabled")
  personalBio               String?   @map("personal_bio")
  prescriptionHeader        String?   @map("prescription_header")
  favoritesMedications      Json?     @map("favorites_medications")
  favoritesDiagnoses        Json?     @map("favorites_diagnoses")
  favoritesExams            Json?     @map("favorites_exams")
  favoritesTemplates        Json?     @map("favorites_templates")
  aiPersonalization         Json?     @map("ai_personalization")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("doctor_profiles")
}

model NurseProfile {
  id                  String  @id @default(uuid()) @map("id")
  userId              String  @unique @map("user_id")
  coren               String  @map("coren")
  corenState          String  @map("coren_state")
  specialization      String? @map("specialization")
  canPrescribeNursing Boolean @default(false) @map("can_prescribe_nursing")
  shiftPreference     Shift?  @map("shift_preference")
  certifications      Json?   @map("certifications")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nurse_profiles")
}

model ProfessionalSchedule {
  id               String  @id @default(uuid()) @map("id")
  professionalId   String  @map("professional_id")
  dayOfWeek        Int     @map("day_of_week")
  startTime        String  @map("start_time")
  endTime          String  @map("end_time")
  location         String? @map("location")
  room             String? @map("room")
  isTelemedicine   Boolean @default(false) @map("is_telemedicine")
  slotDuration     Int     @default(30) @map("slot_duration")
  breakStart       String? @map("break_start")
  breakEnd         String? @map("break_end")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  professional User @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, dayOfWeek])
  @@map("professional_schedules")
}

model Patient {
  id                       String        @id @default(uuid()) @map("id")
  tenantId                 String        @map("tenant_id")
  mrn                      String        @map("mrn")
  fullName                 String        @map("full_name")
  socialName               String?       @map("social_name")
  cpf                      String?       @map("cpf")
