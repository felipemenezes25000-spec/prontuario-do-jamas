// NURSING HANDOFF (Passagem de Plantao)
// ============================================================================

model NursingHandoff {
  id          String   @id @default(uuid()) @map("id")
  sectorId    String?  @map("sector_id")
  fromNurseId String   @map("from_nurse_id")
  toNurseId   String   @map("to_nurse_id")
  patients    Json     @map("patients")
  shift       String?  @map("shift")
  tenantId    String   @map("tenant_id")
  createdAt   DateTime @default(now()) @map("created_at")

  fromNurse User   @relation("HandoffFrom", fields: [fromNurseId], references: [id], onDelete: Restrict)
  toNurse   User   @relation("HandoffTo", fields: [toNurseId], references: [id], onDelete: Restrict)
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([fromNurseId])
  @@index([toNurseId])
  @@index([createdAt])
  @@map("nursing_handoffs")
}
